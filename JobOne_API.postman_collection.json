{
	"info": {
		"name": "JobOne.in Admin API",
		"description": "API for managing posts, categories, and states in JobOne.in",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    pm.collectionVariables.set(\"token\", jsonData.data.token);",
							"    console.log(\"Token saved:\", jsonData.data.token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/admin/login",
					"host": ["{{base_url}}"],
					"path": ["admin", "login"]
				}
			},
			"response": []
		},
		{
			"name": "2. Get All Posts",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/posts?per_page=10",
					"host": ["{{base_url}}"],
					"path": ["posts"],
					"query": [
						{
							"key": "type",
							"value": "job",
							"disabled": true
						},
						{
							"key": "category_id",
							"value": "1",
							"disabled": true
						},
						{
							"key": "is_published",
							"value": "1",
							"disabled": true
						},
						{
							"key": "per_page",
							"value": "10"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Get Single Post",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/posts/1",
					"host": ["{{base_url}}"],
					"path": ["posts", "1"]
				}
			},
			"response": []
		},
		{
			"name": "4. Create Post",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"UPSC CSE 2026 Notification Released\",\n    \"type\": \"job\",\n    \"category_id\": 2,\n    \"state_id\": null,\n    \"short_description\": \"UPSC Civil Services Examination 2026 notification has been released\",\n    \"content\": \"<h2>UPSC CSE 2026</h2><p>The Union Public Service Commission has released the notification for Civil Services Examination 2026. Candidates can apply online from the official website.</p><h3>Important Dates</h3><ul><li>Notification Date: March 10, 2026</li><li>Last Date to Apply: April 30, 2026</li><li>Prelims Exam Date: June 15, 2026</li></ul>\",\n    \"notification_date\": \"2026-03-10\",\n    \"last_date\": \"2026-04-30\",\n    \"total_posts\": 1000,\n    \"important_links\": \"{\\\"official_website\\\": \\\"https://upsc.gov.in\\\", \\\"apply_link\\\": \\\"https://upsconline.nic.in\\\"}\",\n    \"is_featured\": true,\n    \"is_published\": true\n}"
				},
				"url": {
					"raw": "{{base_url}}/posts",
					"host": ["{{base_url}}"],
					"path": ["posts"]
				}
			},
			"response": []
		},
		{
			"name": "5. Update Post",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"UPSC CSE 2026 - Updated Notification\",\n    \"is_featured\": false,\n    \"last_date\": \"2026-05-15\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/posts/1",
					"host": ["{{base_url}}"],
					"path": ["posts", "1"]
				}
			},
			"response": []
		},
		{
			"name": "6. Delete Post",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/posts/1",
					"host": ["{{base_url}}"],
					"path": ["posts", "1"]
				}
			},
			"response": []
		},
		{
			"name": "7. Get All Categories",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/categories",
					"host": ["{{base_url}}"],
					"path": ["categories"]
				}
			},
			"response": []
		},
		{
			"name": "8. Get All States",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/states",
					"host": ["{{base_url}}"],
					"path": ["states"]
				}
			},
			"response": []
		},
		{
			"name": "9. Logout",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/admin/logout",
					"host": ["{{base_url}}"],
					"path": ["admin", "logout"]
				}
			},
			"response": []
		}
	]
}
